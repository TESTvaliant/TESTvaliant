{
  "redirects": [
    { "source": "/services", "destination": "/", "permanent": true },
    { "source": "/services/", "destination": "/", "permanent": true },
    { "source": "/about-us", "destination": "/", "permanent": true },
    { "source": "/about-us/", "destination": "/", "permanent": true }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/[^.]+", "dest": "/index.html" }
  ]
